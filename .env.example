# Environment Configuration for Dashboard Monitoring System
# Copy this file to .env and update with your actual values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=8000
HOST=localhost

# =============================================================================
# DATABASE CONFIGURATION (MongoDB)
# =============================================================================
DB_HOST=localhost
DB_PORT=27017
DB_NAME=dashboard_monitoring
DB_USERNAME=
DB_PASSWORD=
DB_AUTH_SOURCE=admin

# Database connection pool settings
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=1
DB_MAX_IDLE_TIME=30000

# Data retention settings (in seconds)
METRICS_RETENTION_SECONDS=2592000    # 30 days
ALERTS_RETENTION_SECONDS=7776000     # 90 days
EVENTS_RETENTION_SECONDS=15552000    # 180 days

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# OpenTelemetry Configuration
SERVICE_NAME=dashboard-monitoring
SERVICE_VERSION=1.0.0
SERVICE_NAMESPACE=monitoring

# Jaeger Configuration
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Prometheus Configuration
PROMETHEUS_METRICS_PORT=9464

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@dashboard-monitoring.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_METRICS_COLLECTION=true
ENABLE_DISTRIBUTED_TRACING=true
ENABLE_ALERT_NOTIFICATIONS=true

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Monitoring Configuration  
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Application Metadata
APP_NAME=electrode-monitoring-server
APP_VERSION=1.0.0
APP_DESCRIPTION=Enhanced monitoring server with metrics and health endpoints

# File Upload Configuration
MAX_FILE_SIZE=10mb
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf

# Database Configuration (configure when needed)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=electrode_db
# DB_USER=electrode_user
# DB_PASSWORD=your_secure_password
