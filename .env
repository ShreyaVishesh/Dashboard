# Application Configuration
NODE_ENV=development
PORT=8000
LOG_LEVEL=info

# Security Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Monitoring Configuration
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Application Metadata
APP_NAME=electrode-monitoring-server
APP_VERSION=1.0.0
APP_DESCRIPTION=Enhanced monitoring server with metrics and health endpoints

# File Upload Configuration
MAX_FILE_SIZE=10mb
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf

# Database Configuration (for future use)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=electrode_db
# DB_USER=electrode_user
# DB_PASSWORD=your_secure_password

# External Services (for future use)
# REDIS_URL=redis://localhost:6379
# ELASTICSEARCH_URL=http://localhost:9200

# Notification Configuration (for future use)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
