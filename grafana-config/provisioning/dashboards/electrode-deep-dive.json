{
  "id": null,
  "title": "Electrode Operations Deep Dive",
  "tags": [
    "electrode",
    "operations",
    "analysis"
  ],
  "style": "dark",
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Electrode Operations Overview",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(electrode_operations_total{job=\"electrode-app\"}[5m]))",
          "legendFormat": "Operations/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Average Operation Duration",
      "type": "gauge",
      "targets": [
        {
          "expr": "rate(electrode_operation_duration_seconds_sum{job=\"electrode-app\"}[5m]) / rate(electrode_operation_duration_seconds_count{job=\"electrode-app\"}[5m])",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "unit": "s",
          "min": 0,
          "max": 3
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Operation Success Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "(sum(rate(electrode_operations_total{job=\"electrode-app\",status=\"success\"}[5m])) / sum(rate(electrode_operations_total{job=\"electrode-app\"}[5m]))) * 100",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      }
    },
    {
      "id": 4,
      "title": "Electrode Operations by Type",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (operation) (rate(electrode_operations_total{job=\"electrode-app\"}[5m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "pieType": "pie",
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "visible",
          "placement": "right"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 5,
      "title": "Response Time Distribution",
      "type": "histogram",
      "targets": [
        {
          "expr": "rate(electrode_operation_duration_seconds_bucket{job=\"electrode-app\"}[5m])",
          "legendFormat": "{{le}}s",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 6,
      "title": "Operations Timeline",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(electrode_operations_total{job=\"electrode-app\"}[1m])",
          "legendFormat": "{{operation}} - {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "hue",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 4,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "visible",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 17
      }
    },
    {
      "id": 7,
      "title": "Electrode Health Score",
      "type": "stat",
      "targets": [
        {
          "expr": "(\n  (sum(rate(electrode_operations_total{job=\"electrode-app\",status=\"success\"}[5m])) / sum(rate(electrode_operations_total{job=\"electrode-app\"}[5m]))) * 0.4 +\n  (1 - (rate(electrode_operation_duration_seconds_sum{job=\"electrode-app\"}[5m]) / rate(electrode_operation_duration_seconds_count{job=\"electrode-app\"}[5m])) / 2) * 0.3 +\n  (rate(http_requests_total{job=\"electrode-app\",status_code=\"200\"}[5m]) / rate(http_requests_total{job=\"electrode-app\"}[5m])) * 0.3\n) * 100",
          "legendFormat": "Health Score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 25
      }
    },
    {
      "id": 8,
      "title": "Recent Error Events",
      "type": "logs",
      "targets": [
        {
          "expr": "rate(electrode_operations_total{job=\"electrode-app\",status=\"error\"}[1m])",
          "legendFormat": "{{operation}} error",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 25
      }
    }
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  }
}
